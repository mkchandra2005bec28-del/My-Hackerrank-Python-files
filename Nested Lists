if __name__ == '__main__':
    students = []
    
    # Read input and build nested list
    for _ in range(int(input())):
        name = input()
        score = float(input())
        students.append([name, score])
    
    # 1. Get all unique scores and sort them to find the second lowest
    # Using a set comprehension for efficiency
    unique_scores = sorted(set(student[1] for student in students))
    second_lowest_grade = unique_scores[1]
    
    # 2. Collect names of students who have the second lowest grade
    # Using a list comprehension to filter
    result_names = [student[0] for student in students if student[1] == second_lowest_grade]
    
    # 3. Sort the names alphabetically
    result_names.sort()
    
    # 4. Print each name
    for name in result_names:
        print(name)
