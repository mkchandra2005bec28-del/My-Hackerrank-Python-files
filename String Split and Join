
def split_and_join(line):
    # Step 1: Split the string into a list of words using " " as the delimiter
    words = line.split(" ")
    
    # Step 2: Join the list of words back into a single string using "-" as the separator
    result = "-".join(words)
    
    return result

if __name__ == '__main__':
    line = input()
    result = split_and_join(line)
    print(result)

