from collections import defaultdict

def solve():
    # Read n and m
    n, m = map(int, input().split())
    
    # Initialize defaultdict with a list factory
    d = defaultdict(list)
    
    # Read Group A: Store 1-based indices
    for i in range(1, n + 1):
        word = input().strip()
        d[word].append(str(i))
    
    # Read Group B and check against Group A
    for _ in range(m):
        word_b = input().strip()
        
        if word_b in d:
            # Join the stored indices with spaces
            print(" ".join(d[word_b]))
        else:
            # Word not found in Group A
            print("-1")

if __name__ == "__main__":
    solve()

