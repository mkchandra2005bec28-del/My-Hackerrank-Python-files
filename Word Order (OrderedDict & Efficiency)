from collections import OrderedDict

def count_words():
   
    n = int(input())
    word_map = OrderedDict()
    
    for _ in range(n):
        word = input().strip()
      
        word_map[word] = word_map.get(word, 0) + 1
    
    print(len(word_map))
   
    print(*word_map.values())

if __name__ == '__main__':
    count_words()
