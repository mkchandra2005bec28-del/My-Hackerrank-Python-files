import re

def decode_matrix():
 
    first_multiple_input = input().split()
    n = int(first_multiple_input[0])
    m = int(first_multiple_input[1])

    matrix = []
    for _ in range(n):
        matrix.append(input())

    decoded_string = ""
    for j in range(m):
        for i in range(n):
            decoded_string += matrix[i][j]



    final_output = re.sub(r'(?<=\w)([^\w]+)(?=\w)', ' ', decoded_string)
    
    print(final_output)

if __name__ == '__main__':
    decode_matrix()
