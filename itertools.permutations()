# Enter your code here. Read input from STDIN. Print output to STDOUT
from itertools import permutations

# Read string S and integer k
s, k = input().split()
k = int(k)

# Sort the string lexicographically first
# This ensures permutations are generated in the correct order
s_sorted = sorted(s)

# Generate permutations of size k
result = list(permutations(s_sorted, k))

# Join the tuples into strings and print each on a new line
for p in result:
    print("".join(p))
