from collections import deque

def process_deque_operations():
    d = deque()
    
    # Read the number of operations
    try:
        n = int(input().strip())
    except EOFError:
        return

    for _ in range(n):
        # Split the input line into components (e.g., ["append", "1"])
        input_data = input().split()
        method_name = input_data[0]
        
        # If the method has an argument (like append 1)
        if len(input_data) > 1:
            method_value = input_data[1]
            # Use getattr to find the method on 'd' and call it with the value
            getattr(d, method_name)(method_value)
        else:
            # Call method without arguments (like pop)
            getattr(d, method_name)()

    # Print all elements separated by a space
    print(*(d))

if __name__ == "__main__":
    process_deque_operations()
